{
  "manifest_version": 3,
  "name": "Leitor de Artigos",
  "version": "1.0.0",
  "description": "Abre um modo de leitura limpo em paginas de artigo onde o navegador nao libera a leitura avancada nativa.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Abrir leitor de artigos",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "toggle-reader-mode": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Alterna o modo de leitura da extensao"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "reader.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
